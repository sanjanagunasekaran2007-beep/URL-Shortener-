rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /links/{linkId} {
      // Anyone can read a shortened link for redirection and dashboard
      allow read: if true;
      
      // Anyone can create a shortened link
      allow create: if request.resource.data.originalUrl is string 
                    && request.resource.data.clicks == 0
                    && request.resource.data.createdAt is int;
                    
      // Anyone can increment the click count of a shortened link
      allow update: if request.resource.data.originalUrl == resource.data.originalUrl
                    && request.resource.data.createdAt == resource.data.createdAt
                    && request.resource.data.clicks == resource.data.clicks + 1;
                    
      // Deletions are forbidden publicly
      allow delete: if false;
    }
  }
}
